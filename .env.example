# Copy this file to .env and fill in your values before running docker compose
AIRFLOW_UID=50000

# Your Gmail address used for Airflow alert emails
AIRFLOW_ALERT_EMAIL=your@gmail.com

# Gmail App Password (NOT your normal Gmail password)
# Generate at: https://myaccount.google.com/apppasswords
AIRFLOW_SMTP_PASSWORD=xxxx xxxx xxxx xxxx

# Secret keys for Airflow security
AIRFLOW_FERNET_KEY=your_fernet_key_here
AIRFLOW_WEBSERVER_SECRET_KEY=your_webserver_secret_key_here
